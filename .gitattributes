# Set default behavior to automatically normalize line endings.
* text=auto

# Force common text files to use LF (Unix line endings) for cross-platform compilation safety (e.g. windows local dev vs windows/linux runner)
*.cs text eol=lf
*.axaml text eol=lf
*.xaml text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.slnx text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.config text eol=lf
*.xml text eol=lf
*.manifest text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Keep binary files untouched by Git's line ending replacement engine
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.db binary
*.duckdb binary
*.zip binary
