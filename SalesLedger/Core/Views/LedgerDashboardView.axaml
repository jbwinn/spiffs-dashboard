<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SalesLedger.Core.ViewModels"
             xmlns:models="using:SalesLedger.Core.Models"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
             x:Class="SalesLedger.Core.Views.LedgerDashboardView"
             x:DataType="vm:LedgerDashboardViewModel"
             Background="#0F172A"> <!-- Slate-900 -->

    <UserControl.Styles>
        <Style Selector="DataGridRow StackPanel#ActionPanel">
            <Setter Property="Opacity" Value="0.0"/>
        </Style>
        <Style Selector="DataGridRow:pointerover StackPanel#ActionPanel">
            <Setter Property="Opacity" Value="1.0"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Main Scrollable Dashboard Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24" Margin="24">
                
                <!-- TOP BAR: Controls & Action Triggers -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Bottom">
                        <Button Content="Import CSV Data..." 
                                Command="{Binding ShowImportDialogCommand}" 
                                Background="#8B5CF6" Foreground="White" 
                                FontWeight="Bold" Padding="16,8" CornerRadius="6" Height="36" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Add & Finalize Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Bottom">
                        <Button Content="+ Add Transaction" 
                                Command="{Binding ShowAddSaleDialogCommand}" 
                                Background="#3B82F6" Foreground="White" 
                                FontWeight="Bold" Padding="16,8" CornerRadius="6" Height="36" VerticalContentAlignment="Center"/>
                        
                        <Button Content="Finalize Pay Period" 
                                Command="{Binding ShowPeriodCloseDialogCommand}" 
                                Background="#10B981" Foreground="White" 
                                FontWeight="Bold" Padding="16,8" CornerRadius="6" Height="36" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- KPI METRICS GRID (4 CARDS) -->
                <Grid ColumnDefinitions="*, *, *, *">
                    <!-- Total Sales Card -->
                    <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="20" Margin="0,0,10,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Total Sales Volume" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalSales, StringFormat='\{0:C}'}" Foreground="#3B82F6" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Units Sold Card -->
                    <Border Grid.Column="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="20" Margin="10,0,10,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Total Units Sold" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalUnitsSold}" Foreground="#10B981" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Total Commission Card -->
                    <Border Grid.Column="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="20" Margin="10,0,10,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Total Commission Earned" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalCommission, StringFormat='\{0:C}'}" Foreground="#F59E0B" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Average Sale Price Card -->
                    <Border Grid.Column="3" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="20" Margin="10,0,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Average Sale Price (ASP)" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding AverageSalePrice, StringFormat='\{0:C}'}" Foreground="#EC4899" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- MIDDLE SECTION: Trends Chart (Full Width) -->
                <Grid ColumnDefinitions="*" Height="300">
                    <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="20">
                        <Grid RowDefinitions="Auto, *">
                            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,12">
                                <TextBlock Text="Sales Trends Graph" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                    <ComboBox ItemsSource="{Binding TimeframeOptions}" SelectedItem="{Binding SelectedTimeframe, Mode=TwoWay}" Width="150" Height="30" VerticalContentAlignment="Center" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding MetricOptions}" SelectedItem="{Binding SelectedMetric, Mode=TwoWay}" Width="120" Height="30" VerticalContentAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Graph Bars Layout Container -->
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding ChartItems}" VerticalAlignment="Bottom" Height="210">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" VerticalAlignment="Bottom"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ChartItem">
                                        <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Bottom" Background="Transparent">
                                            <ToolTip.Tip>
                                                <Border Background="#0F172A" BorderBrush="#475569" BorderThickness="1" CornerRadius="8" Padding="14">
                                                    <StackPanel Spacing="8" MinWidth="200">
                                                        <TextBlock Text="{Binding Label}" Foreground="White" FontSize="13" FontWeight="Bold"/>
                                                        
                                                        <Grid ColumnDefinitions="*, Auto">
                                                            <TextBlock Text="Total Sales:" Foreground="#94A3B8" FontSize="11"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding TotalSalesText}" Foreground="#3B82F6" FontSize="11" FontWeight="Bold"/>
                                                        </Grid>
                                                        <Grid ColumnDefinitions="*, Auto">
                                                            <TextBlock Text="Units Sold:" Foreground="#94A3B8" FontSize="11"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding TotalUnitsText}" Foreground="#10B981" FontSize="11" FontWeight="Bold"/>
                                                        </Grid>
                                                        <Grid ColumnDefinitions="*, Auto">
                                                            <TextBlock Text="Total Commission:" Foreground="#94A3B8" FontSize="11"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding TotalCommissionText}" Foreground="#F59E0B" FontSize="11" FontWeight="Bold"/>
                                                        </Grid>
                                                        <Grid ColumnDefinitions="*, Auto">
                                                            <TextBlock Text="Highest Sale:" Foreground="#94A3B8" FontSize="11"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding HighestSaleText}" Foreground="#EC4899" FontSize="11" FontWeight="Bold"/>
                                                        </Grid>

                                                        <Border BorderBrush="#334155" BorderThickness="0,0,0,1" Margin="0,4"/>
                                                        <TextBlock Text="Category Breakdown" Foreground="#E2E8F0" FontSize="10" FontWeight="Bold"/>
                                                        <ItemsControl ItemsSource="{Binding CategoriesBreakdown}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:CategoryDisplay">
                                                                    <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                                                        <TextBlock Text="{Binding Name}" Foreground="#94A3B8" FontSize="10"/>
                                                                        <TextBlock Grid.Column="1" Text="{Binding ValueText}" Foreground="#F8FAFC" FontSize="10" FontWeight="SemiBold" Margin="12,0,0,0"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </ToolTip.Tip>
                                            
                                            <!-- Vertical Bar border -->
                                            <Border Width="18" 
                                                    Height="{Binding Height}" 
                                                    Background="#3B82F6" 
                                                    CornerRadius="4,4,0,0" 
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Bottom">
                                                <Border.Styles>
                                                    <Style Selector="Border:pointerover">
                                                        <Setter Property="Background" Value="#60A5FA"/>
                                                    </Style>
                                                </Border.Styles>
                                            </Border>
                                            <!-- Label below bar -->
                                            <TextBlock Text="{Binding Label}" Foreground="#64748B" FontSize="10" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- CATEGORY SALES DISTRIBUTION SECTION -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="20">
                    <Grid RowDefinitions="Auto, *">
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Category Sales Distribution" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Proportional category breakdown for the selected timeframe." FontSize="11" Foreground="#94A3B8"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="View By:" Foreground="#E2E8F0" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding CategoryBreakdownMetricOptions}" 
                                          SelectedItem="{Binding CategoryBreakdownMetric, Mode=TwoWay}" 
                                          Width="140" Height="30" VerticalContentAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                        
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding CategoryBreakdownItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="12"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategoryBreakdownItem">
                                    <Grid RowDefinitions="Auto, Auto" Margin="0,2">
                                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Category}" Foreground="#E2E8F0" FontSize="12" FontWeight="SemiBold"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding ValueText}" Foreground="#94A3B8" FontSize="12"/>
                                                <TextBlock Text="{Binding Percentage, StringFormat='\{0:F1}%'}" Foreground="{Binding Color}" FontSize="12" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <ProgressBar Grid.Row="1" 
                                                     Value="{Binding Percentage}" 
                                                     Minimum="0" Maximum="100" 
                                                     Height="8" 
                                                     Foreground="{Binding Color}" 
                                                     Background="#334155" 
                                                     CornerRadius="4"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- TRANSACTION LEDGER DATA GRID -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="12">
                    <Grid RowDefinitions="Auto, Auto, *">
                        <!-- Header with title and High Value toggle -->
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="12,8,12,12">
                            <TextBlock Text="Recent Sales Ledger" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding HighValueSalesOnly, Mode=TwoWay}" VerticalAlignment="Center">
                                <TextBlock Text="High Value Only (+$1,500)" Foreground="#E2E8F0" FontSize="12"/>
                            </CheckBox>
                        </Grid>
                        
                        <!-- Search & Filter Panel -->
                        <StackPanel Grid.Row="1" Spacing="12" Margin="12,0,12,16">
                            <Grid ColumnDefinitions="2*, *, *, *">
                                <!-- Search input -->
                                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,10,0">
                                    <TextBlock Text="Search Sale" Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding SearchText, Mode=TwoWay}" PlaceholderText="Search SKU, Product, Invoice/Order Code..." Height="32" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Type Filter -->
                                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,10,0">
                                    <TextBlock Text="Sale Type" Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding SaleTypeFilterOptions}" SelectedItem="{Binding SelectedSaleTypeFilter, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32" VerticalContentAlignment="Center" FontSize="12"/>
                                </StackPanel>

                                <!-- Category Filter -->
                                <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,10,0">
                                    <TextBlock Text="Category" Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding CategoryFilterOptions}" SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32" VerticalContentAlignment="Center" FontSize="12"/>
                                </StackPanel>

                                <!-- Date Filter Type -->
                                <StackPanel Grid.Column="3" Spacing="4">
                                    <TextBlock Text="Filter by Date" Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding DateFilterTypeOptions}" SelectedItem="{Binding SelectedDateFilterType, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32" VerticalContentAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Grid>

                            <!-- Custom Date Range Panel (Visible when Custom is selected) -->
                            <StackPanel Spacing="4" IsVisible="{Binding IsCustomDateFilter}">
                                <Grid ColumnDefinitions="*, 12, *">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Start Date" Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
                                        <CalendarDatePicker SelectedDate="{Binding CustomStartDate, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock Text="End Date" Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
                                        <CalendarDatePicker SelectedDate="{Binding CustomEndDate, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- DataGrid -->
                        <DataGrid Grid.Row="2" 
                                  ItemsSource="{Binding RecentSalesView}" 
                                  SelectedItem="{Binding SelectedSale, Mode=TwoWay}"
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  CanUserSortColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserReorderColumns="True"
                                  Height="320"
                                  RowHeight="38"
                                  BorderBrush="#334155"
                                  BorderThickness="1"
                                  Background="#0F172A">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:DataType="models:SaleRecord" Header="Date" Binding="{Binding TransactionDate, StringFormat='\{0:yyyy-MM-dd}'}" Width="Auto" MinWidth="110" CanUserSort="True" SortMemberPath="TransactionDate"/>
                                <DataGridTextColumn x:DataType="models:SaleRecord" Header="Invoice / Order Code" Binding="{Binding InvoiceNumber}" Width="Auto" MinWidth="150" CanUserSort="True" SortMemberPath="InvoiceNumber"/>
                                <DataGridTextColumn x:DataType="models:SaleRecord" Header="Product Name" Binding="{Binding ProductName}" Width="*" MinWidth="180" CanUserSort="True" SortMemberPath="ProductName"/>
                                <DataGridTextColumn x:DataType="models:SaleRecord" Header="Category" Binding="{Binding Category}" Width="Auto" MinWidth="120" CanUserSort="True" SortMemberPath="Category"/>
                                <DataGridTextColumn x:DataType="models:SaleRecord" Header="Price" Binding="{Binding SalePrice, StringFormat='\{0:C}'}" Width="Auto" MinWidth="110" CanUserSort="True" SortMemberPath="SalePrice"/>
                                <DataGridTextColumn x:DataType="models:SaleRecord" Header="Commission" Binding="{Binding CalculatedCommission, StringFormat='\{0:C}'}" Width="Auto" MinWidth="130" CanUserSort="True" SortMemberPath="CalculatedCommission"/>
                                <DataGridTextColumn x:DataType="models:SaleRecord" Header="Status" Binding="{Binding Status}" Width="Auto" MinWidth="160" CanUserSort="True" SortMemberPath="Status"/>
                                
                                <DataGridTemplateColumn x:DataType="models:SaleRecord" Width="110" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="models:SaleRecord">
                                            <StackPanel Name="ActionPanel" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <!-- Edit Button -->
                                                <Button Command="{Binding $parent[DataGrid].((vm:LedgerDashboardViewModel)DataContext).EditSaleCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Edit Transaction"
                                                        Background="#334155" Padding="6,2" CornerRadius="4" BorderThickness="0" Height="26" Width="26" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                                    <TextBlock Text="✎" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Button>
                                                <!-- Process Return Button -->
                                                <Button Command="{Binding $parent[DataGrid].((vm:LedgerDashboardViewModel)DataContext).ProcessReturnCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Process Return"
                                                        Background="#B91C1C" Padding="6,2" CornerRadius="4" BorderThickness="0" Height="26" Width="26" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                                    <TextBlock Text="↶" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Button>
                                                <!-- Delete Button -->
                                                <Button Command="{Binding $parent[DataGrid].((vm:LedgerDashboardViewModel)DataContext).DeleteSaleCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Delete Transaction"
                                                        Background="#EF4444" Padding="6,2" CornerRadius="4" BorderThickness="0" Height="26" Width="26" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                                    <TextBlock Text="✕" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- DIALOG OVERLAY: Add / Edit Transaction -->
        <Grid Background="#B00F172A" IsVisible="{Binding IsSaleDialogVisible}">
            <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="24" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="{Binding DialogTitle}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    
                    <!-- Form fields -->
                    <Grid ColumnDefinitions="*, 12, *">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="{Binding InvoiceLabel}" Foreground="#E2E8F0" FontSize="11"/>
                            <TextBox Text="{Binding InvoiceNumber, Mode=TwoWay}" PlaceholderText="{Binding InvoicePlaceholder}" Height="36" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="SKU / Item code" Foreground="#E2E8F0" FontSize="11"/>
                            <TextBox Text="{Binding Sku, Mode=TwoWay}" PlaceholderText="e.g. SKU-880" Height="36" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Product Name" Foreground="#E2E8F0" FontSize="11"/>
                        <TextBox Text="{Binding ProductName, Mode=TwoWay}" PlaceholderText="e.g. Sony Alpha 7 IV" Height="36" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, 12, *">
                        <Panel Grid.Column="0">
                            <!-- Category (Standard / eBay) -->
                            <StackPanel Spacing="4" IsVisible="{Binding ShowCategory}">
                                <TextBlock Text="Category" Foreground="#E2E8F0" FontSize="11"/>
                                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding Category, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="36"/>
                            </StackPanel>
                            <!-- Warranty Brand (Warranty) -->
                            <StackPanel Spacing="4" IsVisible="{Binding ShowWarranty}">
                                <TextBlock Text="Warranty Brand" Foreground="#E2E8F0" FontSize="11"/>
                                <ComboBox ItemsSource="{Binding WarrantyTypes}" SelectedItem="{Binding WarrantyTypeName, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="36"/>
                            </StackPanel>
                        </Panel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Sale Price" Foreground="#E2E8F0" FontSize="11"/>
                            <NumericUpDown Value="{Binding SalePrice, Mode=TwoWay}" Minimum="0" FormatString="C2" Height="36"/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*, 12, *">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Transaction Date" Foreground="#E2E8F0" FontSize="11"/>
                            <CalendarDatePicker SelectedDate="{Binding TransactionDate, Mode=TwoWay}" Height="36" HorizontalAlignment="Stretch" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Sale Category Type" Foreground="#E2E8F0" FontSize="11"/>
                            <ComboBox SelectedIndex="{Binding SelectedRecordTypeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="36">
                                <ComboBoxItem Content="Standard Sale"/>
                                <ComboBoxItem Content="Warranty Sale"/>
                                <ComboBoxItem Content="eBay Sale"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Standard / eBay Sale Conditional Fields -->
                    <StackPanel Spacing="6" IsVisible="{Binding ShowUsedGear}">
                        <CheckBox IsChecked="{Binding IsUsedGear, Mode=TwoWay}">
                            <TextBlock Text="Is Used Equipment" Foreground="#E2E8F0" FontSize="12"/>
                        </CheckBox>
                    </StackPanel>

                    <!-- Warranty Sale Conditional Fields -->
                    <StackPanel Spacing="12" IsVisible="{Binding ShowWarranty}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Manufacturer Wholesale Price" Foreground="#E2E8F0" FontSize="11"/>
                            <NumericUpDown Value="{Binding ManufacturerPrice, Mode=TwoWay}" Minimum="0" FormatString="C2" Height="36"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Buttons -->
                    <Grid ColumnDefinitions="*, 12, *" Margin="0,12,0,0">
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseSaleDialogCommand}" Background="#334155" Foreground="White" Height="36" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="6"/>
                        <Button Grid.Column="2" Content="Save Entry" Command="{Binding SaveSaleCommand}" Background="#3B82F6" Foreground="White" Height="36" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="6" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- DIALOG OVERLAY: Period Close -->
        <Grid Background="#B00F172A" IsVisible="{Binding IsPeriodCloseVisible}">
            <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="24" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="Finalize Pay Period" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="This action will freeze all pending transactions, locks their status to Paid, and compiles the QuestPDF payout statement. This action cannot be undone." FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap"/>
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="Report Submission Name" Foreground="#E2E8F0" FontSize="11"/>
                        <TextBox Text="{Binding PeriodReportName, Mode=TwoWay}" PlaceholderText="e.g. May 2026 Submission" Height="36" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, 12, *" Margin="0,8,0,0">
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding ClosePeriodCloseDialogCommand}" Background="#334155" Foreground="White" Height="36" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="6"/>
                        <Button Grid.Column="2" Content="Execute Close" Command="{Binding ExecutePeriodCloseCommand}" Background="#10B981" Foreground="White" Height="36" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="6" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- DIALOG OVERLAY: CSV Import Wizard -->
        <Grid Background="#B00F172A" IsVisible="{Binding IsImportDialogVisible}">
            <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="24" Width="520" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="Import CSV Spiff Sheet" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Import transaction data from a CSV spiff sheet. Choose a file, select columns mapping, and insert records." FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap"/>
                    
                    <!-- File browser row -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="CSV File Path" Foreground="#E2E8F0" FontSize="11"/>
                        <Grid ColumnDefinitions="*, 8, Auto">
                            <TextBox Text="{Binding CsvFilePath}" IsReadOnly="True" PlaceholderText="Select file..." Height="36" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseCsvFileCommand}" Background="#334155" Foreground="White" Height="36" VerticalContentAlignment="Center" Padding="12,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- Import Mode -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Import Records As:" Foreground="#E2E8F0" FontSize="11"/>
                        <ComboBox SelectedItem="{Binding ImportAsType, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="36" VerticalContentAlignment="Center">
                            <ComboBox.Items>
                                <x:String>Standard</x:String>
                                <x:String>Warranty</x:String>
                                <x:String>Ebay</x:String>
                            </ComboBox.Items>
                        </ComboBox>
                    </StackPanel>

                    <!-- Map columns panel (visible if a file has headers loaded) -->
                    <StackPanel Spacing="12" IsVisible="{Binding CsvHeaders.Count}">
                        <TextBlock Text="Column Mapping" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,4,0,0"/>

                        <!-- Basic fields mapping grid -->
                        <Grid ColumnDefinitions="*, 12, *">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Date Column" Foreground="#E2E8F0" FontSize="10"/>
                                <ComboBox ItemsSource="{Binding CsvHeaders}" SelectedItem="{Binding SelectedDateHeader, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Invoice / Receipt" Foreground="#E2E8F0" FontSize="10"/>
                                <ComboBox ItemsSource="{Binding CsvHeaders}" SelectedItem="{Binding SelectedInvoiceHeader, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*, 12, *">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Product SKU" Foreground="#E2E8F0" FontSize="10"/>
                                <ComboBox ItemsSource="{Binding CsvHeaders}" SelectedItem="{Binding SelectedSkuHeader, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Product Name" Foreground="#E2E8F0" FontSize="10"/>
                                <ComboBox ItemsSource="{Binding CsvHeaders}" SelectedItem="{Binding SelectedProductNameHeader, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*, 12, *">
                            <StackPanel Grid.Column="0" Spacing="4" IsVisible="{Binding IsStandardOrEbayImport}">
                                <TextBlock Text="Category" Foreground="#E2E8F0" FontSize="10"/>
                                <ComboBox ItemsSource="{Binding CsvHeaders}" SelectedItem="{Binding SelectedCategoryHeader, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Sale Price" Foreground="#E2E8F0" FontSize="10"/>
                                <ComboBox ItemsSource="{Binding CsvHeaders}" SelectedItem="{Binding SelectedPriceHeader, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32"/>
                            </StackPanel>
                        </Grid>

                        <!-- Standard/eBay specific mapper -->
                        <StackPanel Spacing="8" IsVisible="{Binding IsStandardOrEbayImport}">
                            <Grid ColumnDefinitions="*, 12, *">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Is Used Gear Column" Foreground="#E2E8F0" FontSize="10"/>
                                    <ComboBox ItemsSource="{Binding CsvHeaders}" SelectedItem="{Binding SelectedIsUsedHeader, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Default Category Fallback" Foreground="#E2E8F0" FontSize="10"/>
                                    <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding DefaultCategory, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32"/>
                                </StackPanel>
                            </Grid>
                            <CheckBox IsChecked="{Binding AllStandardAreUsed, Mode=TwoWay}">
                                <TextBlock Text="Treat all imports as USED unless marked new" Foreground="#94A3B8" FontSize="10"/>
                            </CheckBox>
                        </StackPanel>

                        <!-- Warranty specific mapper -->
                        <StackPanel Spacing="8" IsVisible="{Binding IsWarrantyImport}">
                            <Grid ColumnDefinitions="*, 12, *">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Warranty Type Column" Foreground="#E2E8F0" FontSize="10"/>
                                    <ComboBox ItemsSource="{Binding CsvHeaders}" SelectedItem="{Binding SelectedWarrantyTypeHeader, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Wholesale Price Column" Foreground="#E2E8F0" FontSize="10"/>
                                    <ComboBox ItemsSource="{Binding CsvHeaders}" SelectedItem="{Binding SelectedWholesalePriceHeader, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Default Warranty Fallback" Foreground="#E2E8F0" FontSize="10"/>
                                <ComboBox ItemsSource="{Binding WarrantyTypes}" SelectedItem="{Binding DefaultWarrantyType, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="32"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Import Actions -->
                    <Grid ColumnDefinitions="*, 12, *" Margin="0,12,0,0">
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseImportDialogCommand}" Background="#334155" Foreground="White" Height="36" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="6"/>
                        <Button Grid.Column="2" Content="Process Import" Command="{Binding ExecuteCsvImportCommand}" Background="#8B5CF6" Foreground="White" Height="36" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="6" FontWeight="SemiBold" IsEnabled="{Binding CsvHeaders.Count}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
