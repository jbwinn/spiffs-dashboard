<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SalesLedger.Core.ViewModels"
             xmlns:models="using:SalesLedger.Core.Models"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="750"
             x:Class="SalesLedger.Core.Views.FullScreenSettingsView"
             x:DataType="vm:FullScreenSettingsViewModel"
             Background="{DynamicResource BgAppDark}"
             FontFamily="{DynamicResource FontPrimary}">

    <Grid>
        <TabControl Margin="24" Theme="{StaticResource {x:Type TabControl}}">
        <TabControl.Styles>
            <Style Selector="TabItem">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                <Setter Property="Padding" Value="16,12"/>
            </Style>
            <Style Selector="TabItem:selected">
                <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
            </Style>
        </TabControl.Styles>

        <!-- TAB 1: Profile -->
        <TabItem Header="Identity Profile">
            <Border Background="{DynamicResource BgCardDark}" BorderBrush="{DynamicResource BorderSlate}" BorderThickness="1" CornerRadius="8" Padding="24" MaxWidth="600" HorizontalAlignment="Left" Margin="0,16,0,0">
                <StackPanel Spacing="16">
                    <TextBlock Text="Identity Settings" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Set your name for report generations and statements." FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                    
                    <StackPanel Spacing="6">
                        <TextBlock Text="User Display Name" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="12"/>
                        <TextBox Text="{Binding UserDisplayName, Mode=TwoWay}" PlaceholderText="Enter your full name" Theme="{StaticResource {x:Type TextBox}}"/>
                    </StackPanel>

                    <!-- Save Status Display -->
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="{Binding IsStatusError, Converter={StaticResource StatusColorConverter}}" 
                               FontSize="12" 
                               IsVisible="{Binding HasStatusMessage}"/>

                    <Button Content="Save Profile" 
                            Command="{Binding SaveProfileCommand}" 
                            Background="{DynamicResource AccentBlue}" 
                            Foreground="White" 
                            Padding="16,8" 
                            CornerRadius="6" 
                            HorizontalAlignment="Left"/>

                    <!-- Application Updates Section -->
                    <Border BorderBrush="{DynamicResource BorderSlate}" BorderThickness="0,1,0,0" Margin="0,20,0,0" Padding="0,20,0,0">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Application Updates" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Manage auto-updating and manually check for updates." FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                            
                            <CheckBox IsChecked="{Binding AutoUpdateEnabled, Mode=TwoWay}">
                                <TextBlock Text="Enable Auto-Updating (Checks on startup)" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                            </CheckBox>

                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                <Button Content="Check for Updates" 
                                        Command="{Binding CheckForUpdatesManualCommand}" 
                                        Background="{DynamicResource AccentGreen}" 
                                        Foreground="White" 
                                        Padding="16,8" 
                                        CornerRadius="6"
                                        IsEnabled="{Binding IsNotCheckingForUpdates}"/>
                                
                                <Button Content="Test Update UI" 
                                        Command="{Binding TestUpdateUiCommand}" 
                                        IsVisible="{Binding IsDebugMode}"
                                        Background="{DynamicResource AccentBlue}" 
                                        Foreground="White" 
                                        Padding="16,8" 
                                        CornerRadius="6"/>
                                
                                <TextBlock Text="{Binding UpdateStatusMessage}" 
                                           Foreground="{DynamicResource TextSecondary}" 
                                           VerticalAlignment="Center" 
                                           FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Database Utilities Section -->
                    <Border BorderBrush="{DynamicResource BorderSlate}" BorderThickness="0,1,0,0" Margin="0,20,0,0" Padding="0,20,0,0">
                        <StackPanel Spacing="12">
                            <TextBlock Text="System Utilities" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Clear all transactions, payouts, and reset settings back to default presets." FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                            
                            <Button Content="Reset Database" 
                                    Command="{Binding ResetDatabaseCommand}" 
                                    Background="{DynamicResource AccentRed}" 
                                    Foreground="White" 
                                    Padding="16,8" 
                                    CornerRadius="6" 
                                    HorizontalAlignment="Left"
                                    FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </TabItem>

        <!-- TAB 2: Taxonomy -->
        <TabItem Header="Taxonomy &amp; Lists">
            <Grid ColumnDefinitions="*, *" Margin="0,16,0,0" HorizontalAlignment="Stretch">
                <!-- Column 1: Product Categories -->
                <Border Grid.Column="0" Background="{DynamicResource BgCardDark}" BorderBrush="{DynamicResource BorderSlate}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,12,0">
                    <Grid RowDefinitions="Auto, Auto, *">
                        <TextBlock Grid.Row="0" Text="Product Categories" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0" Text="Manage categories for sales logs." FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" Margin="0,20,0,8"/>

                        <!-- Add Category Form -->
                        <Grid Grid.Row="1" ColumnDefinitions="*, 8, Auto" Margin="0,8">
                            <TextBox Grid.Column="0" Text="{Binding NewCategoryName, Mode=TwoWay}" PlaceholderText="Add new category..." Height="36" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="Add" Command="{Binding AddCategoryCommand}" Background="{DynamicResource AccentGreen}" Foreground="White" Padding="16,0" Height="36" VerticalContentAlignment="Center"/>
                        </Grid>

                        <!-- Categories Grid -->
                        <ScrollViewer Grid.Row="2" Margin="0,8,0,0">
                            <ItemsControl ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:AppCategory">
                                        <Border BorderBrush="{DynamicResource BorderSlate}" BorderThickness="0,0,0,1" Padding="8,10">
                                            <Grid ColumnDefinitions="*, Auto, Auto">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <!-- Icon indicator for preset -->
                                                    <Border Background="{Binding IsSystemPreset, Converter={StaticResource PresetToColorConverter}}" CornerRadius="4" Padding="4,2">
                                                        <TextBlock Text="{Binding IsSystemPreset, Converter={StaticResource PresetToTextConverter}}" Foreground="White" FontSize="8" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" 
                                                               Foreground="{Binding IsActive, Converter={StaticResource BoolToColorConverter}}" 
                                                               FontSize="13" 
                                                               FontWeight="Medium" 
                                                               TextDecorations="{Binding IsActive, Converter={StaticResource BoolToDecorationConverter}}"/>
                                                </StackPanel>
                                                
                                                <!-- Action Buttons -->
                                                <Button Grid.Column="1" 
                                                        Content="{Binding IsActive, Converter={StaticResource ActiveToStatusTextConverter}}" 
                                                        Command="{Binding $parent[UserControl].((vm:FullScreenSettingsViewModel)DataContext).ToggleCategoryActiveCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding !IsSystemPreset}" 
                                                        FontSize="11" 
                                                        Background="{DynamicResource BorderSlate}" 
                                                        Foreground="{DynamicResource TextPrimary}"
                                                        Margin="0,0,6,0"/>

                                                <Button Grid.Column="2" 
                                                        Content="Delete" 
                                                        Command="{Binding $parent[UserControl].((vm:FullScreenSettingsViewModel)DataContext).DeleteCategoryCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding !IsSystemPreset}" 
                                                        FontSize="11" 
                                                        Background="{DynamicResource AccentRed}" 
                                                        Foreground="White"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Column 2: Warranty Types -->
                <Border Grid.Column="1" Background="{DynamicResource BgCardDark}" BorderBrush="{DynamicResource BorderSlate}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="12,0,0,0">
                    <Grid RowDefinitions="Auto, Auto, *">
                        <TextBlock Grid.Row="0" Text="Warranty Types" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0" Text="Manage available warranty programs." FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" Margin="0,20,0,8"/>

                        <!-- Add Warranty Form -->
                        <Grid Grid.Row="1" ColumnDefinitions="*, 8, Auto" Margin="0,8">
                            <TextBox Grid.Column="0" Text="{Binding NewWarrantyTypeName, Mode=TwoWay}" PlaceholderText="Add new warranty..." Height="36" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="Add" Command="{Binding AddWarrantyTypeCommand}" Background="{DynamicResource AccentGreen}" Foreground="White" Padding="16,0" Height="36" VerticalContentAlignment="Center"/>
                        </Grid>

                        <!-- Warranty List -->
                        <ScrollViewer Grid.Row="2" Margin="0,8,0,0">
                            <ItemsControl ItemsSource="{Binding WarrantyTypes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:AppWarrantyType">
                                        <Border BorderBrush="{DynamicResource BorderSlate}" BorderThickness="0,0,0,1" Padding="8,10">
                                            <Grid ColumnDefinitions="*, Auto, Auto">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <Border Background="{Binding IsSystemPreset, Converter={StaticResource PresetToColorConverter}}" CornerRadius="4" Padding="4,2">
                                                        <TextBlock Text="{Binding IsSystemPreset, Converter={StaticResource PresetToTextConverter}}" Foreground="White" FontSize="8" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" 
                                                               Foreground="{Binding IsActive, Converter={StaticResource BoolToColorConverter}}" 
                                                               FontSize="13" 
                                                               FontWeight="Medium"
                                                               TextDecorations="{Binding IsActive, Converter={StaticResource BoolToDecorationConverter}}"/>
                                                </StackPanel>

                                                <Button Grid.Column="1" 
                                                        Content="{Binding IsActive, Converter={StaticResource ActiveToStatusTextConverter}}" 
                                                        Command="{Binding $parent[UserControl].((vm:FullScreenSettingsViewModel)DataContext).ToggleWarrantyTypeActiveCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding !IsSystemPreset}" 
                                                        FontSize="11" 
                                                        Background="{DynamicResource BorderSlate}" 
                                                        Foreground="{DynamicResource TextPrimary}"
                                                        Margin="0,0,6,0"/>

                                                <Button Grid.Column="2" 
                                                        Content="Delete" 
                                                        Command="{Binding $parent[UserControl].((vm:FullScreenSettingsViewModel)DataContext).DeleteWarrantyTypeCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding !IsSystemPreset}" 
                                                        FontSize="11" 
                                                        Background="{DynamicResource AccentRed}" 
                                                        Foreground="White"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <!-- TAB 3: Commission Waterfall -->
        <TabItem Header="Commission Rules Waterfall">
            <Grid ColumnDefinitions="*, 24, 400" Margin="0,16,0,0">
                <!-- Left: Rules Reordering Waterfall -->
                <Border Grid.Column="0" Background="{DynamicResource BgCardDark}" BorderBrush="{DynamicResource BorderSlate}" BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid RowDefinitions="Auto, *">
                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Priority Waterfall (First-Match Wins)" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Rearrange rules to solve overlap conflicts. Active transaction evaluations run top-to-bottom." FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>

                        <!-- Rules List -->
                        <ScrollViewer Grid.Row="1">
                            <ItemsControl ItemsSource="{Binding Rules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:CommissionRule">
                                        <Border Background="{DynamicResource BgAppDark}" BorderBrush="{DynamicResource BorderSlate}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                                                <!-- Rank Order -->
                                                <Border Grid.Column="0" Background="{DynamicResource AccentBlue}" Width="24" Height="24" CornerRadius="12" Margin="0,0,12,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding PriorityOrder}" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Rule Info -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding RuleName}" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding Scope}" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                                        <TextBlock Text="•" Foreground="{DynamicResource TextMuted}" FontSize="11" IsVisible="{Binding Scope, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='CategorySpecific'}"/>
                                                        <TextBlock Text="{Binding TargetCategory}" Foreground="{DynamicResource TextSecondary}" FontSize="11" IsVisible="{Binding Scope, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='CategorySpecific'}"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Rule Value -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,24,0">
                                                    <TextBlock Text="{Binding CalculationType, Converter={StaticResource CalculationTypeToTextConverter}}" Foreground="{DynamicResource TextSecondary}" FontSize="10" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding RuleValue}" Foreground="{DynamicResource AccentGreen}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                </StackPanel>

                                                <!-- Up / Down Actions -->
                                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <Button Content="▲" 
                                                            Command="{Binding $parent[UserControl].((vm:FullScreenSettingsViewModel)DataContext).MoveRuleUpCommand}"
                                                            CommandParameter="{Binding}"
                                                            Background="{DynamicResource BorderSlate}" Foreground="{DynamicResource TextPrimary}" Padding="8,4" FontSize="10"/>
                                                    <Button Content="▼" 
                                                            Command="{Binding $parent[UserControl].((vm:FullScreenSettingsViewModel)DataContext).MoveRuleDownCommand}"
                                                            CommandParameter="{Binding}"
                                                            Background="{DynamicResource BorderSlate}" Foreground="{DynamicResource TextPrimary}" Padding="8,4" FontSize="10"/>
                                                    <Button Content="Edit" 
                                                            Command="{Binding $parent[UserControl].((vm:FullScreenSettingsViewModel)DataContext).EditCommissionRuleCommand}"
                                                            CommandParameter="{Binding}"
                                                            Background="{DynamicResource AccentBlue}" Foreground="White" Padding="12,4" FontSize="11"/>
                                                    <Button Content="Delete" 
                                                            Command="{Binding $parent[UserControl].((vm:FullScreenSettingsViewModel)DataContext).DeleteCommissionRuleCommand}"
                                                            CommandParameter="{Binding}"
                                                            Background="{DynamicResource AccentRed}" Foreground="White" Padding="12,4" FontSize="11"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Right: Create Rule Panel -->
                <Border Grid.Column="2" Background="{DynamicResource BgCardDark}" BorderBrush="{DynamicResource BorderSlate}" BorderThickness="1" CornerRadius="8" Padding="20" Height="500" VerticalAlignment="Top">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Create Payout Rule" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        
                        <!-- Name -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Rule Name" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                            <TextBox Text="{Binding NewRuleName, Mode=TwoWay}" PlaceholderText="e.g. Cameras High Margin" Height="36" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- Scope -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Rule Scope" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding ScopeOptions}" SelectedItem="{Binding NewRuleScope, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="36"/>
                        </StackPanel>

                        <!-- Target Category -->
                        <StackPanel Spacing="6" IsVisible="{Binding NewRuleScope, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='CategorySpecific'}">
                            <TextBlock Text="Target Category" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding ActiveCategoryNames}" SelectedItem="{Binding NewRuleTargetCategory, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="36"/>
                        </StackPanel>

                        <!-- Calculation Type -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Payout Method" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding PayoutTypeOptions}" SelectedItem="{Binding NewRuleCalculationType, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="36"/>
                        </StackPanel>

                        <!-- Value -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Rule Value (e.g. 0.10 for 10% or 25.00 for flat)" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                            <NumericUpDown Value="{Binding NewRuleValue, Mode=TwoWay}" Minimum="0" FormatString="N2" Height="36"/>
                        </StackPanel>

                        <!-- Add Button -->
                        <Button Content="Add to Waterfall" Command="{Binding AddCommissionRuleCommand}" Background="{DynamicResource AccentGreen}" Foreground="White" Padding="0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="6" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>

    <!-- Edit Rule Overlay Popup Dialog -->
    <Grid Background="{DynamicResource BgOverlay}"
          IsVisible="{Binding IsEditRuleDialogVisible}"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Border Background="{DynamicResource BgCardDark}"
                BorderBrush="{DynamicResource BorderSlate}"
                BorderThickness="1.5"
                CornerRadius="12"
                Width="440"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BoxShadow="0 20 25 -5 #99000000, 0 10 10 -5 #99000000">
            <StackPanel Spacing="20">
                <TextBlock Text="Edit Payout Rule" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>

                <!-- Name -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Rule Name" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                    <TextBox Text="{Binding EditRuleName, Mode=TwoWay}" PlaceholderText="Rule Name" Height="36" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Scope -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Rule Scope" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding ScopeOptions}" SelectedItem="{Binding EditRuleScope, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="36"/>
                </StackPanel>

                <!-- Target Category -->
                <StackPanel Spacing="6" IsVisible="{Binding EditRuleScope, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='CategorySpecific'}">
                    <TextBlock Text="Target Category" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding ActiveCategoryNames}" SelectedItem="{Binding EditRuleTargetCategory, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="36"/>
                </StackPanel>

                <!-- Calculation Type -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Payout Method" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding PayoutTypeOptions}" SelectedItem="{Binding EditRuleCalculationType, Mode=TwoWay}" HorizontalAlignment="Stretch" Height="36"/>
                </StackPanel>

                <!-- Value -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Rule Value (e.g. 0.10 for 10% or 25.00 for flat)" Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                    <NumericUpDown Value="{Binding EditRuleValue, Mode=TwoWay}" Minimum="0" FormatString="N2" Height="36"/>
                </StackPanel>

                <!-- Actions -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="16" Margin="0,8,0,0">
                    <Button Grid.Column="0" 
                            Content="Cancel" 
                            Command="{Binding CloseEditRuleDialogCommand}" 
                            Background="{DynamicResource BorderSlate}" 
                            Foreground="{DynamicResource TextPrimary}"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="12,10" 
                            CornerRadius="6"
                            BorderThickness="0">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="{DynamicResource TextMuted}"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    <Button Grid.Column="1" 
                            Content="Save Changes" 
                            Command="{Binding SaveEditedRuleCommand}" 
                            Background="{DynamicResource AccentGreen}" 
                            Foreground="White"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="12,10" 
                            CornerRadius="6"
                            BorderThickness="0">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="{DynamicResource AccentGreenHover}"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Grid>
</UserControl>
